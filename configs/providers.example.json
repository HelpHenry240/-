    "custom": {
      "label": "自定义 OpenAI-compatible API",
      "type": "openai_compatible",
      "base_url": "",
      "model": "",
      "api_key_env": "CUSTOM_VLM_API_KEY",
      "description": "在网页中填写 Base URL、模型名、请求头和额外参数"
    }
